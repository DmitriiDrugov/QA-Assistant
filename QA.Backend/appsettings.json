{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "KnowledgeBase": {
    "FilePath": "knowledge_base.txt",
    "ChunkSize": 800,
    "MaxQuestionLength": 500
  },
  "Ai": {
    "Provider": "OpenRouter",
    "BaseUrl": "https://openrouter.ai/api",
    "ChatCompletionsPath": "/v1/chat/completions",
    "Model": "openai/gpt-oss-20b:free",
    "ApiKey": ""
  },
  "Database": {
    "ConnectionString": "Server=YOUR_HOST;Port=3306;Database=AI_IT_Assistant;User=YOUR_USER;Password=YOUR_PASSWORD;SslMode=Required;"
  },
  "Jwt": {
    "Issuer": "QA.Backend",
    "Audience": "AURA.Frontend",
    "Key": "development-only-key-change-this-before-production-2026",
    "AccessTokenExpiresHours": 24
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://localhost:3000"
    ]
  }
}
